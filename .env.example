# Backend Worker URL for sending notifications
# This should point to your backend service (Cloudflare Worker, Node.js server, etc.)
# The backend should handle:
# - POST /discord - Send Discord notifications
# - POST /whatsapp - Send WhatsApp messages
# - POST /thankyou - Generate thank you messages

VITE_WORKER_URL=https://your-worker-url.com

# Example backend endpoints:
# POST /discord - Discord webhook integration
# POST /whatsapp - WhatsApp message via Twilio or WhatsApp Business API
# POST /thankyou - AI-generated thank you message

# ============================================
# WhatsApp Integration via Twilio
# ============================================
# For WhatsApp integration, you can use:
# 1. Twilio WhatsApp API (RECOMMENDED)
# 2. WhatsApp Business API (Advanced)
# 3. Custom backend service

# Backend Environment Variables (for your Cloud Worker/Backend)
# Set these in your Cloudflare Worker settings or backend .env

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Twilio WhatsApp From Number (Business WhatsApp number)
# Get this after setting up WhatsApp in Twilio
TWILIO_WHATSAPP_FROM=whatsapp:+91XXXXXXXXXX

# Owner WhatsApp Number (where you receive notifications)
WHATSAPP_PHONE_NUMBER=+91 9689102662

# Discord Webhook (optional, for Discord notifications)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL
